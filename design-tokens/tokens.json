{
  "$schema": "./schema.notes.json",
  "name": "personal-centurion-v5",
  "version": "5.0.0",
  "description": "Canonical Centurion v5 design tokens — source: sales site app/globals.css",
  "fonts": {
    "sans": "Instrument Sans",
    "display": "Instrument Serif",
    "mono": "JetBrains Mono"
  },
  "radius": {
    "base": "0.25rem",
    "sm": "0rem",
    "md": "0.125rem",
    "lg": "0.25rem",
    "xl": "0.5rem"
  },
  "light": {
    "background": { "oklch": "oklch(0.985 0.002 90)", "hex": "#fafaf9" },
    "foreground": { "oklch": "oklch(0.12 0.01 60)", "hex": "#1a1612" },
    "card": { "oklch": "oklch(1 0 0)", "hex": "#ffffff" },
    "secondary": { "oklch": "oklch(0.96 0.005 90)", "hex": "#f3f2ee" },
    "muted": { "oklch": "oklch(0.94 0.005 90)", "hex": "#ecebe7" },
    "mutedForeground": { "oklch": "oklch(0.45 0.02 60)", "hex": "#5e534a" },
    "accentSurface": { "oklch": "oklch(0.92 0.01 90)", "hex": "#e7e4dd" },
    "border": { "oklch": "oklch(0.88 0.01 90)", "hex": "#dad7d0" },
    "input": { "oklch": "oklch(0.92 0.01 90)", "hex": "#e7e4dd" },
    "destructive": { "oklch": "oklch(0.577 0.245 27.325)", "hex": "#e7000b" },
    "interactive": { "hex": "#2563eb", "note": "App/chrome interactive (links, tab selection). Web marketing CTAs prefer near-ink primary." },
    "interactiveSoft": { "hex": "#60a5fa" },
    "warmCompanion": { "hex": "#b87a36", "note": "Optional warmth — not primary chrome." }
  },
  "dark": {
    "note": "Derived near-ink dark for native apps (v5 web is light-first).",
    "background": { "hex": "#0c0a08" },
    "foreground": { "hex": "#fafaf9" },
    "card": { "hex": "#1a1714" },
    "secondary": { "hex": "#221e1a" },
    "muted": { "hex": "#2a2520" },
    "mutedForeground": { "hex": "#a39a8e" },
    "accentSurface": { "hex": "#2f2a24" },
    "border": { "hex": "#3a342c" },
    "input": { "hex": "#2a2520" },
    "interactive": { "hex": "#60a5fa" },
    "interactiveSoft": { "hex": "#93c5fd" },
    "warmCompanion": { "hex": "#d7a868" }
  }
}
